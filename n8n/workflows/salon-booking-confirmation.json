      "position": [
        260,
        300
      ],
      "webhookId": "salon-booking-confirmation"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/salonflow-email-smtp",
        "authentication": "none",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            {
              "name": "channel",
              "value": "email"
            },
            {
              "name": "type",
              "value": "confirm"
            },
            {
              "name": "customer_name",
              "value": "={{ $json.client_name || ($json.body && $json.body.client_name) || \"Kunde\" }}"
            },
            {
              "name": "customer_phone",
              "value": "={{ $json.client_phone || ($json.body && $json.body.client_phone) || \"\" }}"
            },
            {
              "name": "customer_email",
              "value": "={{ $json.client_email || ($json.body && $json.body.client_email) || \"\" }}"
            },
            {
              "name": "service_name",
              "value": "={{ $json.service_name || ($json.body && $json.body.service_name) || \"Service\" }}"
            },
            {
              "name": "stylist_name",
              "value": "={{ $json.stylist_name || ($json.body && $json.body.stylist_name) || \"Stylist\" }}"
            },
            {
              "name": "start_time",
              "value": "={{ $json.appointment_time || ($json.body && $json.body.appointment_time) || \"\" }}"
            },
            {
              "name": "salon_name",
              "value": "={{ $json.salon_name || ($json.body && $json.body.salon_name) || \"SalonFlow Demo\" }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json",
              "neverError": false,
              "fullResponse": false
            }
          }
        }
      },
      "id": "node-send-confirmation-email",
      "name": "Send Confirmation Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
